diff --git a/Packages/com.unity.ide.zededitor/Editor/ZedScriptEditor.cs b/Packages/com.unity.ide.zededitor/Editor/ZedScriptEditor.cs new file mode 100644 index 00000000..960f79cb --- /dev/null +++ b/Packages/com.unity.ide.zededitor/Editor/ZedScriptEditor.cs @@ -0,0 +1,110 @@ +using System; +using System.IO; +using Unity.CodeEditor; +using UnityEditor; +using UnityEngine; + +namespace Unity.Zed.Editor +{ +    [InitializeOnLoad] +    public class ZedScriptEditor : IExternalCodeEditor +    { +        static ZedScriptEditor() +        { +            CodeEditor.Register(new ZedScriptEditor()); +        } + +        CodeEditor.Installation[] IExternalCodeEditor.Installations +        { +            get +            { +                var zedPath = ZedDiscovery.FindZed(); +                return new[] +                { +                    new CodeEditor.Installation +                    { +                        Name = "Zed", +                        Path = zedPath ?? "zed" +                    } +                }; +            } +        } + +        public void Initialize(string editorInstallationPath) +        { +        } + +        public void OnGUI() +        { +            var package = UnityEditor.PackageManager.PackageInfo.FindForAssembly(GetType().Assembly); +            if (package == null) +                return; + +            GUILayout.BeginHorizontal(); +            GUILayout.FlexibleSpace(); + +            var style = new GUIStyle +            { +                richText = true, +                margin = new RectOffset(0, 4, 0, 0) +            }; + +            GUILayout.Label($"<size=10><color=grey>{package.displayName} v{package.version} enabled</color></size>", style); +            GUILayout.EndHorizontal(); +        } + +        public bool OpenProject(string path, int line, int column) +        { +            var projectDirectory = Directory.GetParent(Application.dataPath)?.FullName ?? Application.dataPath; +            ZedSolutionGeneratorBridge.